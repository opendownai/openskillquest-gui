{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OpenSkillQuest",
  "version": "0.1.0",
  "identifier": "com.opendown.openskillquest",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "OpenSkillQuest",
        "width": 1100,
        "height": 750,
        "minWidth": 900,
        "minHeight": 600,
        "center": true,
        "resizable": true,
        "decorations": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' https://opendown.ai; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "publisher": "OpenDown",
    "shortDescription": "RPG for ClawHub Skills",
    "longDescription": "OpenSkillQuest is a desktop RPG game where you complete quests by installing ClawHub skills. Earn EXP, level up, unlock titles, and share your build!"
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDkxRDRGQjA4NEY0NEMwOUQKUldTZHdFUlBDUHZVa2ZlaHZXQ3lKYzZ5Q1N2em1CNUxvTEZrbVA1dHNJUE5mYUtqMExpb09IcHUK",
      "endpoints": [
        "https://github.com/opendownai/openskillquest-gui/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
